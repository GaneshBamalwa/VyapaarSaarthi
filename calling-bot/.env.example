# Vyapaar Saarthi — Calling Bot (Twilio Voice)

# Port this service listens on (8000 = backend, 8001 = legacy legal bot).
PORT=8002

# URL of the running Vyapaar Saarthi backend (FastAPI).
BACKEND_URL=http://localhost:8000

# Language for Twilio speech recognition AND spoken replies (e.g. hi-IN, en-IN).
VOICE_LANGUAGE=hi-IN

# How long Twilio waits for the caller to stop speaking ("auto" or seconds).
SPEECH_TIMEOUT=auto

# Optional custom greeting played when a call connects.
# VOICE_GREETING=Namaste! Vyapaar Saarthi mein aapka swagat hai.

# Twilio auth token — validates that webhooks really come from Twilio.
# Leave blank to skip validation during local testing.
TWILIO_AUTH_TOKEN=

# Public HTTPS base URL (e.g. your ngrok URL) — needed for signature validation
# when running behind a proxy. Example: https://abcd-1234.ngrok-free.app
PUBLIC_BASE_URL=
