# App
APP_NAME=Vyapaar Saarthi
DEBUG=true
ENVIRONMENT=development

# Database (SQLite for dev, switch to Postgres for prod)
DATABASE_URL=sqlite:///./vyapaar_saarthi.db

# ── Google Cloud Platform ───────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Leave blank to use gcloud ADC (gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=

# Set to "true" to use mock GCP services (no credentials needed for local dev)
USE_MOCK_GCP=false

# ── Google AI Studio (testing without GCP billing) ────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Set to "true" to use Vertex AI via gcloud ADC (production/deployment)
USE_VERTEX_AI=true

# ── Gemini / Vertex AI Models ─────────────────────────────────────────────────
# Workhorse model — fast, cheap, supports reasoning and multimodal inputs
GEMINI_FLASH_MODEL=gemini-2.5-flash

# Pro model — highly advanced for notice translation, GSTR validation, deep reasoning
GEMINI_PRO_MODEL=gemini-2.5-pro

# Live model — optimized for real-time bidirectional streaming voice/multimodal chat
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# ── Speech Models ─────────────────────────────────────────────────────────────
# Cloud Speech-to-Text model (chirp_2 = best multilingual/code-switched support)
STT_MODEL=chirp_2
STT_LANGUAGE=hi-IN

# Gemini model used as STT fallback when Cloud Speech is unavailable
STT_GEMINI_MODEL=gemini-2.5-flash

# Gemini TTS — replaces Cloud TTS, no extra credentials needed
# Available voices: Aoede, Puck, Charon, Kore, Fenrir, Leda, Orus, Zephyr
TTS_GEMINI_MODEL=gemini-2.5-flash-preview-tts
TTS_GEMINI_VOICE=Aoede
TTS_LANGUAGE=hi-IN

# ── GCS / Storage ─────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=your-gcs-bucket-name

# ── HITL ──────────────────────────────────────────────────────────────────────
# HITL threshold (orders below this confidence need human approval)
HITL_CONFIDENCE_THRESHOLD=0.8

# ── CORS ──────────────────────────────────────────────────────────────────────
# CORS (frontend URLs)
CORS_ORIGINS=["http://localhost:5174","http://localhost:5173","http://localhost:3000"]

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
TELEGRAM_ADMIN_IDS=123456789
TELEGRAM_USE_GEMINI=true
