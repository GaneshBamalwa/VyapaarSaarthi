GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Leave blank to use gcloud ADC (gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=

# Set to "true" to use mock GCP services (no credentials needed for local dev)
USE_MOCK_GCP=true

# ── Google AI Studio (testing without GCP billing) ────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Set to "true" to use Vertex AI via gcloud ADC (production/deployment)
USE_VERTEX_AI=false

# ── Gemini / Vertex AI Models ─────────────────────────────────────────────────
# Fast model — used for chat, intent routing, invoice drafts, reminders
GEMINI_FLASH_MODEL=gemini-2.0-flash-001

# Pro model — used for notice translation, GSTR validation, deep reasoning
GEMINI_PRO_MODEL=gemini-2.5-pro-preview-05-06

# Live model — used for bidirectional streaming voice chat
GEMINI_LIVE_MODEL=gemini-2.0-flash

# ── Speech Models ─────────────────────────────────────────────────────────────
# Cloud Speech-to-Text model (chirp_2 = best multilingual/code-switched support)
STT_MODEL=chirp_2
STT_LANGUAGE=hi-IN

# Cloud Text-to-Speech voice (hi-IN-Neural2-A = expressive Hindi female studio voice)
# Other options: hi-IN-Neural2-B (male), hi-IN-Neural2-C, hi-IN-Neural2-D
TTS_VOICE=hi-IN-Neural2-A
TTS_LANGUAGE=hi-IN

# ── App Config ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./vyapaar_mvp.db
